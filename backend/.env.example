# ============================================================
# OncoTriage Backend — 环境变量配置
#
# 复制为 .env 后填入真实值。.env 不进 git。
# 修改任何阈值前请确认是否需要临床委员会签字（见各段落标注）。
# ============================================================


# ════════════════════════════════════════════════════════════
# 数据库
# ════════════════════════════════════════════════════════════

# PostgreSQL 连接串。生产环境用独立 DB 用户 + SSL。
DATABASE_URL=postgresql+psycopg://sz:sz_dev_password@localhost:5432/sz_dev

# SQLAlchemy 连接池大小。LLM 调用是 I/O 密集，建议 ≥ uvicorn worker 数 × 2。
DATABASE_POOL_SIZE=10


# ════════════════════════════════════════════════════════════
# LLM —— 感知层
# 支持两种 SDK 协议：'anthropic' | 'openai'
# 'openai' 通道兼容 OpenAI 官方 / DeepSeek / Qwen / OpenRouter / 本地 vLLM、ollama 等
# ════════════════════════════════════════════════════════════

# 选哪个 provider。切换只改这一项，不需要改代码。
LLM_PROVIDER=anthropic

# LLM 调用超时（秒）。中位时延 3-8s，留足缓冲。超时算抽取失败，触发 checklist 兜底。
LLM_TIMEOUT_SECONDS=15

# 单次响应最大 token 数。结构化抽取的 JSON 通常 < 1000 token。
LLM_MAX_TOKENS=2000

# 温度。0.0 = 完全确定性；抽取场景必须 0，不允许"创造性"。
LLM_TEMPERATURE=0.0


# ── Anthropic 通道 ──────────────────────────────────────────
# API 密钥。生产环境用 secret manager 注入，不进 .env 文件。
ANTHROPIC_API_KEY=sk-ant-...

# 模型版本。换模型必须更新 assessment.extraction_model_version 字段，
# 用于审计回溯——3 年后能查出"当时哪个模型抽的"。
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# base_url 留空 = 走 Anthropic 官方 (https://api.anthropic.com)。
# 也可指向兼容端点：
#   DeepSeek (Anthropic-compat): https://api.deepseek.com/anthropic
#     —— 此时 ANTHROPIC_API_KEY 填 DeepSeek key、ANTHROPIC_MODEL 填 deepseek-v4-pro 等
# ANTHROPIC_BASE_URL=


# ── OpenAI 兼容通道 ────────────────────────────────────────
# 切换 provider 只改 LLM_PROVIDER + 这一段，不需要改代码。
# OPENAI_API_KEY=sk-...
#
# base_url 决定打到哪家 provider：
#   OpenAI 官方:  https://api.openai.com/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   Qwen:        https://dashscope.aliyuncs.com/compatible-mode/v1
#   OpenRouter:  https://openrouter.ai/api/v1
#   本地 vLLM:   http://localhost:8000/v1
#   ollama:      http://localhost:11434/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini


# ════════════════════════════════════════════════════════════
# 应用 / 服务
# ════════════════════════════════════════════════════════════

# 'dev' | 'staging' | 'prod'。影响日志详细度、SQL echo、错误堆栈是否暴露给前端。
APP_ENV=dev

# 日志级别。'DEBUG' | 'INFO' | 'WARN' | 'ERROR'。
LOG_LEVEL=INFO

# CORS 白名单。多个域名用逗号分隔。生产收紧到具体域名。
CORS_ALLOW_ORIGINS=http://localhost:5173


# ════════════════════════════════════════════════════════════
# 规则引擎 — 决策层
# ════════════════════════════════════════════════════════════

# 规则引擎版本号。每次 rules.yaml 改动必须 bump，写入 assessment.rule_engine_version
# 用于审计——能查出某次评估当时用了哪个版本的规则。
RULE_ENGINE_VERSION=1.0.0

# 规则文件路径（相对 backend/）。MVP 阶段共享 docs/rules/rules.yaml；
# 未来规则更新频繁后可迁到独立 git 仓库或配置中心。
RULES_FILE_PATH=../docs/rules/rules.yaml


# ════════════════════════════════════════════════════════════
# Feature flags
# ════════════════════════════════════════════════════════════

# Advanced 时序分析开关。关 = Base 子方案（仅当前次评估），
# 开 = Advanced（含最近 7 天趋势规则，如 R030_worsening_fatigue_trend）。
FEATURE_TIMESERIES=false


# ════════════════════════════════════════════════════════════
# 可观测性 / 埋点
# ════════════════════════════════════════════════════════════

# 5 个核心事件的去向。'stdout'（dev）| 'kafka'（prod）| 'noop'（test）。
EVENT_SINK=stdout

# Kafka brokers（仅 EVENT_SINK=kafka 时使用）。
# EVENT_KAFKA_BROKERS=kafka1:9092,kafka2:9092
# EVENT_KAFKA_TOPIC=oncotriage.events


# ════════════════════════════════════════════════════════════
# ⚕️ 临床阈值 — Bad Case 自动触发条件
# ⚠️ 修改这些值需要临床委员会签字，不是纯工程决策。
#    所有阈值的目的是决定"什么样的评估需要人工 review"。
# ════════════════════════════════════════════════════════════

# LLM 抽取置信度低于此值 → 自动 flag 到 case_review (trigger=auto_low_confidence)。
# 偏低（如 0.4）= 漏掉低质量抽取；偏高（如 0.8）= review 队列爆炸。
# 默认 0.6 基于"宁愿多看不愿漏看"的医疗原则。
LOW_CONFIDENCE_THRESHOLD=0.6

# 同用户先 low 后 high 的时间窗（小时），命中 → auto_outcome_mismatch flag。
# 24h 是化疗副作用快速恶化的典型时长（如 FN）。
OUTCOME_MISMATCH_WINDOW_HOURS=24

# 连续 N 次高风险结果但用户未点"联系团队" → auto_repeat_high_no_action flag。
# 提示规则可能过于敏感（误报），或建议文案没说清严重性。
REPEAT_HIGH_NO_ACTION_COUNT=3


# ════════════════════════════════════════════════════════════
# 幂等性
# ════════════════════════════════════════════════════════════

# idempotency_key 有效期（小时）。Stripe 默认 24h；超期后相同 key 视为新提交。
# 太短会误拒重试；太长会让"24h 后真的二次评估"失败。
IDEMPOTENCY_KEY_TTL_HOURS=24


# ════════════════════════════════════════════════════════════
# 时序分析（Advanced 子方案）
# ════════════════════════════════════════════════════════════

# v_user_trend_7d 视图的窗口长度（天）。规则引擎读趋势时用此窗口。
# 7 天是化疗周期常见单位（21 天周期里恢复期约 1 周）。
TREND_WINDOW_DAYS=7

# 趋势"加重 / 减轻 / 稳定"判定的对比子窗（天）。
# 视图把窗口前半 vs 后半的均值做对比；3 天对应 7 天窗口的中点附近。
TREND_COMPARISON_DAYS=3


# ════════════════════════════════════════════════════════════
# 数据飞轮 / 合规（暂未启用，预留）
# ════════════════════════════════════════════════════════════

# 默认 IRB 项目 ID（用于 DEIDENTIFIED_RESEARCH consent 的 recipient_class）。
# DEFAULT_IRB_PROJECT_ID=irb_proj_2026_breast_cancer_followup

# k-anonymity 阈值。聚合给药企的统计必须涉及 ≥ K 个用户才能输出。
# 行业惯例 K=20。
# AGGREGATION_K_ANONYMITY_THRESHOLD=20
